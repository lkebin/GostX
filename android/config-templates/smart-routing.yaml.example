# GostX 智能分流配置
#
# DNS 分流规则：
#   - gfwlist 域名  → 1.1.1.1（DoH，经代理，防 DNS 污染）
#   - 其他域名      → 114.114.114.114（UDP，经代理）
#
# IP 路由规则：
#   - 中国大陆 IP   → 直连
#   - 私有/回环 IP  → 直连
#   - IPv6          → 直连（全部）
#   - 境外 IP       → 经代理（<YOUR_SERVER_IP>:<PORT>）
#
# ⚠️  使用前必须先运行脚本下载数据文件：
#   scripts/update_lists.sh
#   然后通过 ADB 推送到设备：
#   adb push gfwlist_domains.txt /data/user/0/cn.liukebin.GostX/files/
#   adb push china_ip_list.txt   /data/user/0/cn.liukebin.GostX/files/

services:
  - name: vpn
    addr: :0
    handler:
      type: tungo
      chain: upstream
    listener:
      type: tungo

  - name: dns
    addr: :10053
    handler:
      type: dns
      chain: upstream   # DNS 查询经代理发出（避免 1.1.1.1 被封锁）
    listener:
      type: dns
      metadata:
        mode: udp
    forwarder:
      nodes:
        # 非 gfwlist 域名优先使用国内 DNS
        - name: domestic
          addr: udp://114.114.114.114:53
          bypass: gfwlist   # gfwlist 域名跳过此节点，由 overseas 处理
        # gfwlist 域名使用 1.1.1.1 DoH（不受 DNS 污染影响）
        - name: overseas
          addr: https://1.1.1.1:443/dns-query

bypasses:
  # gfwlist 域名列表（由 update_lists.sh 生成）
  - name: gfwlist
    file:
      path: /data/user/0/cn.liukebin.GostX/files/gfwlist_domains.txt
    reload: 24h   # 每 24 小时自动重载

  # 直连规则：私有 IP、IPv6、中国大陆 IP
  - name: direct
    matchers:
      - 127.0.0.0/8      # loopback
      - 10.0.0.0/8       # RFC 1918
      - 172.16.0.0/12    # RFC 1918
      - 192.168.0.0/16   # RFC 1918
      - ::/0             # 所有 IPv6 直连
    file:
      path: /data/user/0/cn.liukebin.GostX/files/china_ip_list.txt
    reload: 24h   # 每 24 小时自动重载

chains:
  - name: upstream
    hops:
      - name: hop0
        bypass: direct   # 命中 direct bypass 的流量直连，不进入代理节点
        nodes:
          - name: server
            addr: <YOUR_SERVER_IP>:<PORT>
            connector:
              type: http2
            dialer:
              type: http2
            metadata:
              path: /<YOUR_SECRET_PATH>
