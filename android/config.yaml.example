services:
  - name: vpn
    addr: :0
    handler:
      type: tungo
      chain: upstream
    listener:
      type: tungo

chains:
  - name: upstream
    hops:
      - name: hop0
        nodes:
          - name: server
            addr: example.com
            connector:
              type: ss
              metadata:
                method: chacha20-ietf-poly1305
                password: password
            dialer:
              type: tcp

